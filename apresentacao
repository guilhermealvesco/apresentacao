      metric:'22', mlabel:'reuniões por mês', name:'Caio Menezes', role:'Sócio · Agência de performance, SP'},
  s2:{seg:'SaaS', prod:'Geração de Demanda',
      quote:'Nosso funil tava cheio de teste grátis que não virava contrato. A Resolve colocou decisor na mesa: <strong>31 demos qualificadas em 60 dias</strong> e o CAC caiu 40%.',
      metric:'-40%', mlabel:'de CAC em 60 dias', name:'Renata Lopes', role:'CEO · SaaS de gestão, PE'},
  s3:{seg:'Segurança Armada', prod:'Ativo Comercial',
      quote:'Nesse mercado ninguém liga pedindo proposta, é relacionamento. A Resolve abriu portas que a gente rondava há anos: <strong>14 visitas técnicas por mês</strong> e 3 contratos anuais no primeiro trimestre.',
      metric:'14', mlabel:'visitas técnicas por mês', name:'Marcos Vieira', role:'Diretor · Segurança patrimonial, PE'},
  s4:{seg:'Contabilidade', prod:'Implantação Comercial',
      quote:'Contabilidade cresce no boca a boca, e boca a boca não escala. Com a cadência da Resolve entraram <strong>38 CNPJs novos na carteira</strong> em 6 meses, todos no nosso ticket ideal.',
      metric:'+38', mlabel:'CNPJs em 6 meses', name:'Patrícia Ramos', role:'Sócia · Contabilidade digital, Recife'},
  s5:{seg:'Eventos', prod:'Geração de Demanda',
      quote:'Evento corporativo se vende meses antes, e a gente só era lembrado em cima da hora. Hoje temos reunião com RH e marketing o ano inteiro: <strong>9 propostas ativas por mês</strong>.',
      metric:'9', mlabel:'propostas ativas por mês', name:'Diego Sales', role:'Fundador · Produtora de eventos, PE'},
  s6:{seg:'Energia Solar', prod:'Geração de Demanda',
      quote:'Anúncio só trazia curioso de telhado residencial. A Resolve foi direto no CNPJ com conta de luz alta: <strong>17 estudos de viabilidade por mês</strong> e o maior contrato da história da empresa.',
      metric:'17', mlabel:'estudos de viabilidade por mês', name:'Eduardo Farias', role:'Diretor Comercial · Integradora solar, NE'},
  s7:{seg:'Indústria e Distribuição', prod:'Ativo Comercial',
      quote:'Nossos representantes vendiam pros mesmos clientes há 10 anos. O BDR dedicado da Resolve abriu 3 estados novos e hoje <strong>40% da receita</strong> vem de cliente que não existia na base.',
      metric:'40%', mlabel:'da receita vinda de clientes novos', name:'Sérgio Andrade', role:'Diretor · Indústria de alimentos, SP'}
};
const modal = document.getElementById('segModal');
function openSeg(id){
  const d = SEGS[id]; if(!d) return;
  document.getElementById('mBadge').textContent = d.seg;
  document.getElementById('mQuote').innerHTML = d.quote;
  document.getElementById('mMetric').textContent = d.metric;
  document.getElementById('mMetricLabel').textContent = d.mlabel;
  document.getElementById('mAvatar').textContent = d.name.split(' ').map(n=>n[0]).slice(0,2).join('');
  document.getElementById('mName').textContent = d.name;
  document.getElementById('mRole').textContent = d.role;
  document.getElementById('mProd').textContent = d.prod;
  modal.classList.add('open');
  document.body.style.overflow = 'hidden';
}
function closeSeg(){
  modal.classList.remove('open');
  document.body.style.overflow = '';
}
document.querySelectorAll('.seg[data-seg]').forEach(b=>b.addEventListener('click',()=>openSeg(b.dataset.seg)));
modal.querySelectorAll('[data-close]').forEach(el=>el.addEventListener('click',closeSeg));
document.addEventListener('keydown',e=>{ if(e.key==='Escape') closeSeg(); });
</script>
