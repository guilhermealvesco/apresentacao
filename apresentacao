<script>
// ===== Cadência interativa =====
const CH = {
  email:   {cls:'email',    label:'E-mail'},
  call:    {cls:'call',     label:'Telefone'},
  linkedin:{cls:'linkedin', label:'LinkedIn'},
  whats:   {cls:'whats',    label:'WhatsApp'}
};
const cadence = [
  {d:1,  t:[['email','E-mail de abertura personalizado por ICP'],['linkedin','Visita e conexão no LinkedIn']]},
  {d:2,  t:[['call','Cold call com script testado e validado'],['whats','WhatsApp de apresentação']]},
  {d:3,  t:[['email','E-mail de valor com contexto do segmento']]},
  {d:4,  t:[['linkedin','DM no LinkedIn com aquecimento prévio'],['call','Segunda tentativa de call']]},
  {d:5,  t:[['whats','WhatsApp com gatilho de dor'],['email','Follow-up do e-mail de abertura']]},
  {d:6,  t:[['call','Call em horário alternativo']]},
  {d:7,  t:[['email','E-mail com prova social'],['linkedin','Interação com conteúdo do decisor']]},
  {d:8,  t:[['whats','WhatsApp de retomada'],['call','Call direcionada ao decisor']]},
  {d:9,  t:[['email','E-mail curto de resposta rápida']]},
  {d:10, t:[['linkedin','DM com convite direto'],['whats','Áudio curto de conexão']]},
  {d:11, t:[['call','Call de qualificação TCM'],['email','E-mail de agenda com horários']]},
  {d:12, t:[['whats','WhatsApp de confirmação de interesse']]},
  {d:13, t:[['call','Última tentativa de call'],['email','E-mail de pré break-up']]},
  {d:14, t:[['whats','Break-up: porta aberta para o futuro'],['email','E-mail de break-up']]}
];
const daysEl = document.getElementById('days');
const detailEl = document.getElementById('cadenceDetail');
cadence.forEach((day,i)=>{
  const el = document.createElement('button');
  el.className = 'day' + (i===0?' active':'');
  el.setAttribute('aria-label','Dia '+day.d);
  el.innerHTML = '<small>Dia</small><b>'+String(day.d).padStart(2,'0')+'</b>'+
    '<span class="day-dots">'+day.t.map(t=>'<i class="dot '+CH[t[0]].cls+'"></i>').join('')+'</span>';
  el.addEventListener('click',()=>{
    document.querySelectorAll('.day').forEach(d=>d.classList.remove('active'));
    el.classList.add('active');
    renderDetail(day);
  });
  daysEl.appendChild(el);
});
function renderDetail(day){
  detailEl.innerHTML = '<h4>Dia '+String(day.d).padStart(2,'0')+' · '+day.t.length+
    (day.t.length>1?' toques':' toque')+'</h4>'+
    day.t.map(t=>'<div class="touch"><i class="dot '+CH[t[0]].cls+'"></i><div><strong style="color:#fff;font-size:.82rem;text-transform:uppercase;letter-spacing:.06em">'+CH[t[0]].label+'</strong><br>'+t[1]+'</div></div>').join('');
}
renderDetail(cadence[0]);

// ===== Tabs =====
document.querySelectorAll('.tab-btn').forEach(btn=>{
  btn.addEventListener('click',()=>{
    document.querySelectorAll('.tab-btn').forEach(b=>{b.classList.remove('active');b.setAttribute('aria-selected','false')});
    document.querySelectorAll('.tab-panel').forEach(p=>p.classList.remove('active'));
    btn.classList.add('active');
    btn.setAttribute('aria-selected','true');
    document.getElementById(btn.dataset.tab).classList.add('active');
  });
});

// ===== Reveal on scroll =====
const io = new IntersectionObserver(entries=>{
  entries.forEach(e=>{ if(e.isIntersecting){ e.target.classList.add('in'); io.unobserve(e.target);} });
},{threshold:.15});
document.querySelectorAll('.reveal').forEach(el=>io.observe(el));

// ===== Counters =====
const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
const co = new IntersectionObserver(entries=>{
  entries.forEach(e=>{
    if(!e.isIntersecting) return;
    co.unobserve(e.target);
    const el = e.target;
    const target = +el.dataset.target;
    const prefix = el.dataset.prefix||'';
    const suffix = el.dataset.suffix||'';
    if(reduced){ el.textContent = prefix+target+suffix; return; }
    const dur = 1300; const start = performance.now();
    function tick(now){
      const p = Math.min((now-start)/dur,1);
      const eased = 1-Math.pow(1-p,3);
      el.textContent = prefix+Math.round(target*eased)+suffix;
      if(p<1) requestAnimationFrame(tick);
    }
    requestAnimationFrame(tick);
  });
},{threshold:.5});
document.querySelectorAll('.count').forEach(el=>co.observe(el));

// ===== Depoimentos por segmento =====
// SUBSTITUIR: trocar nomes, empresas e números por clientes reais com autorização
const SEGS = {
  s1:{seg:'Agência de Marketing', prod:'Ativo Comercial',
